# Database (Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin — default email admin@sellpark.io, password Admin1234! until you set ADMIN_PASSWORD_HASH
ADMIN_EMAIL="admin@sellpark.io"
# Optional: bcrypt hash (npm run admin:hash) — when set, default password is disabled
ADMIN_PASSWORD_HASH=""
ADMIN_SESSION_SECRET="change-this-to-a-long-random-string-in-production"

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Plisio (https://plisio.net/account/api)
PLISIO_API_KEY=""
NEXT_PUBLIC_PLISIO_ENABLED="true"

# SMTP (guest order delivery)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SellPark <admin@sellpark.io>"

# hCaptcha (checkout protection — NOT a bypass solver)
NEXT_PUBLIC_HCAPTCHA_SITEKEY=""
HCAPTCHA_SECRET=""
